{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@gameroman/config/biome", "@gameroman/config/biome/tailwind"],
  "linter": {
    "rules": {
      "complexity": { "noVoid": "error" },
      "style": {
        "useImportType": {
          "level": "error",
          "options": { "style": "separatedType" }
        }
      }
    }
  }
}
